<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns="http://camel.apache.org/schema/spring">
  <route id="support-ticket-open">
    <from uri="direct:support-ticket-open"/>
    <setBody>
      <simple>{"ticketId":"TCK-${exchangeId}","status":"OPEN","summary":"${body[query]}","assignedQueue":"L1-SUPPORT","message":"Support ticket created successfully"}</simple>
    </setBody>
  </route>
</routes>
